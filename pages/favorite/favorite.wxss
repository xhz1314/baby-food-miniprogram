.favoriteHeroCard {
  margin-bottom: 18rpx;
  background: linear-gradient(180deg, #fffdfd 0%, #fff7fa 100%);
  border-color: #f7e8ee;
  box-shadow: 0 12rpx 24rpx rgba(236, 207, 216, 0.12);
}

.favoriteHeroTop {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.favoriteHeroTitleGroup {
  min-width: 0;
  flex: 1;
}

.favoriteBadgeTitle {
  display: inline-flex;
}

.heroBadgeTitle {
  display: inline-flex;
  align-items: center;
  gap: 14rpx;
  padding: 6rpx 0;
}

.heroTitleMark {
  width: 16rpx;
  height: 8rpx;
  border-radius: 999rpx;
  flex: 0 0 auto;
  background: linear-gradient(90deg, #f3c5a9 0%, #e8bdcb 100%);
  opacity: 0.9;
}

.heroTitleMarkRight {
  opacity: 0.72;
}

.heroTitle {
  font-size: 40rpx;
  font-weight: 700;
  color: #604d55;
  line-height: 1.15;
  letter-spacing: 1rpx;
}

.favoriteHeroTitleText {
  color: #604d55;
}

.favoriteHeroSubtitle {
  margin-top: 10rpx;
}

.searchCard {
  margin-bottom: 18rpx;
  padding: 18rpx 18rpx;
}

.searchWrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: #fffafb;
  border: 2rpx solid #f4e0e8;
}

.searchIcon {
  font-size: 24rpx;
  color: #d596a8;
}

.searchInput {
  flex: 1;
  min-width: 0;
  height: 56rpx;
  font-size: 25rpx;
  color: #6a575d;
}

.searchPlaceholder {
  color: #c0a6ae;
}

.searchClear {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #ffeaf1;
  color: #da88a2;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  line-height: 1;
}

.stack {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.empty {
  margin-top: 12rpx;
  text-align: center;
}

.favoriteCard {
  position: relative;
  overflow: hidden;
  padding: 20rpx 20rpx 18rpx;
  border-color: #f4e9ed;
  background: linear-gradient(180deg, #ffffff 0%, #fffbf9 100%);
  box-shadow: 0 10rpx 20rpx rgba(236, 205, 214, 0.12);
}

.favoriteCard::before {
  display: none;
}

.menuCardTop {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.menuHeaderMain {
  flex: 1;
  min-width: 0;
}

.menuHeaderPills {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-wrap: wrap;
}

.menuTypePill {
  margin-left: 4rpx;
}

.metaBadge {
  display: inline-flex;
  align-items: center;
  padding: 7rpx 14rpx;
  border-radius: 999rpx;
  background: #fffdfd;
  border: 2rpx solid #f1e5ea;
  color: #9f828c;
  font-size: 22rpx;
  line-height: 1.2;
}

.cardTitleInline {
  margin-top: 10rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #5f4a52;
  line-height: 1.34;
}

.cardMetaText {
  margin-top: 10rpx;
  font-size: 23rpx;
  color: #99838b;
  line-height: 1.45;
}

.matchHint {
  margin-top: 12rpx;
  font-size: 22rpx;
  line-height: 1.45;
  color: #b08a94;
}

.matchHintLabel {
  color: #d596a8;
}

.ingredientPanel {
  margin-top: 16rpx;
  padding: 16rpx 14rpx 12rpx;
  border-radius: 20rpx;
  background: #fffdfd;
  border: 2rpx solid #f3e8ec;
}

.ingredientPanelHead {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.ingredientPanelTitle {
  color: #6b575f;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.2;
}

.ingredientPanelCount {
  flex: 0 0 auto;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #ffffff;
  border: 2rpx solid #f0e1e7;
  color: #af9099;
  font-size: 22rpx;
  line-height: 1.2;
}

.ingredientTags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 12rpx;
}

.ingredientTag {
  max-width: 100%;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: #ffffff;
  border: 2rpx solid #f3e6eb;
  color: #8f6d76;
  font-size: 21rpx;
  line-height: 1.25;
  box-sizing: border-box;
}

.keywordHighlightText {
  color: #ff5f8f;
  background: rgba(255, 210, 225, 0.58);
  border-radius: 10rpx;
  padding: 0 3rpx;
}

.actions {
  margin-top: 14rpx;
  padding-top: 14rpx;
  border-top: 2rpx solid #f5ebef;
  align-items: center;
}

.cardHint {
  flex: 1;
  color: #af949d;
  font-size: 22rpx;
  line-height: 1.3;
}

.actionBtn {
  padding: 12rpx 20rpx;
  font-size: 23rpx;
  line-height: 1.2;
}

.viewBtn {
  background: linear-gradient(135deg, #ff9fba 0%, #ffb68e 100%);
  color: #ffffff;
  box-shadow: 0 8rpx 16rpx rgba(255, 159, 186, 0.16);
}

@keyframes favoritePulse {
  0% {
    transform: scale(0.94);
  }

  70% {
    transform: scale(1.08);
  }

  100% {
    transform: scale(1);
  }
}

.iconFavoriteBtn {
  width: 58rpx;
  height: 58rpx;
  min-width: 58rpx;
  border-radius: 50%;
  background: linear-gradient(180deg, #fffefd 0%, #fff9fa 100%);
  border: 2rpx solid #ecdde3;
  box-shadow: 0 6rpx 12rpx rgba(227, 203, 211, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;
  position: relative;
}

.iconFavoriteBtn::before {
  content: "";
  position: absolute;
  top: 10rpx;
  left: 12rpx;
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.92);
}

.iconFavoriteBtnActive {
  background: linear-gradient(180deg, #fff1f6 0%, #ffdce7 100%);
  border-color: #f3bccd;
  box-shadow: 0 10rpx 18rpx rgba(238, 166, 191, 0.22);
  animation: favoritePulse 0.24s ease-out;
}

.iconFavoriteBtnActive::after {
  content: "";
  position: absolute;
  top: 7rpx;
  right: 9rpx;
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #f8c2d3;
}

.favoriteHeart {
  width: 20rpx;
  height: 18rpx;
  position: relative;
  transform: rotate(-45deg);
  border-radius: 4rpx;
  background: #d6bcc5;
}

.favoriteHeart::before,
.favoriteHeart::after {
  content: "";
  position: absolute;
  width: 20rpx;
  height: 18rpx;
  border-radius: 50%;
  background: inherit;
}

.favoriteHeart::before {
  top: -9rpx;
  left: 0;
}

.favoriteHeart::after {
  top: 0;
  left: 9rpx;
}

.favoriteHeartActive {
  background: #ef88a6;
  transform: rotate(-45deg) scale(1.08);
}

.favoriteHeartInner {
  width: 11rpx;
  height: 10rpx;
  position: absolute;
  top: 4rpx;
  left: 4rpx;
  border-radius: 3rpx;
  background: #fffdfd;
}

.favoriteHeartInner::before,
.favoriteHeartInner::after {
  content: "";
  position: absolute;
  width: 11rpx;
  height: 10rpx;
  border-radius: 50%;
  background: inherit;
}

.favoriteHeartInner::before {
  top: -5rpx;
  left: 0;
}

.favoriteHeartInner::after {
  top: 0;
  left: 5rpx;
}

.favoriteHeartInnerActive {
  width: 6rpx;
  height: 5rpx;
  top: 2rpx;
  left: 7rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.75);
}

.favoriteHeartInnerActive::before,
.favoriteHeartInnerActive::after {
  width: 6rpx;
  height: 5rpx;
}

.favoriteHeartInnerActive::before {
  top: -2rpx;
  left: 0;
}

.favoriteHeartInnerActive::after {
  top: 0;
  left: 2rpx;
}

.iconFavoriteBtn::after {
  border: none;
}

.loadingDotWrap {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  margin-bottom: 12rpx;
}

.loadingDot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #f3bfd0;
  opacity: 0.9;
}