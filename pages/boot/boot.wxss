@keyframes bootDotBounce {
  0%,
  80%,
  100% {
    transform: scale(0.78);
    opacity: 0.5;
  }

  40% {
    transform: scale(1);
    opacity: 1;
  }
}

.bootPage {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  box-sizing: border-box;
  background: #fff4f7;
}

.bootMain {
  width: 100%;
  text-align: center;
}

.bootBadge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
  background: #fff8e8;
  color: #c68a49;
  font-size: 24rpx;
}

.bootTitle {
  margin-top: 24rpx;
  font-size: 42rpx;
  font-weight: 700;
  color: #5f4a52;
}

.bootSubtitle {
  margin-top: 14rpx;
  font-size: 25rpx;
  line-height: 1.7;
  color: #9f8890;
}

.loadingDotWrap {
  margin-top: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.loadingDot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #f2a9bf;
  animation: bootDotBounce 1s infinite ease-in-out;
}

.loadingDotOne {
  animation-delay: 0s;
}

.loadingDotTwo {
  animation-delay: 0.15s;
}

.loadingDotThree {
  animation-delay: 0.3s;
}