<view class="container">
  <view wx:if="{{isLoading}}" class="card loadingCard">
    <view class="loadingDotWrap">
      <view class="loadingDot"></view>
      <view class="loadingDot"></view>
      <view class="loadingDot"></view>
    </view>
    <view class="title">正在加载菜谱</view>
    <view class="muted">马上就把这份小菜谱端上来。</view>
  </view>

  <view wx:if="{{!isLoading && !recipe}}" class="card cuteEmptyCard">
    <view class="title">这份食谱走丢啦</view>
    <view class="muted">请从首页重新挑一份小可爱菜谱。</view>
  </view>

  <view wx:if="{{!isLoading && recipe}}">
    <view class="card detailHeroCard">
      <view class="row detailTopRow">
        <view class="detailTitleWrap">
          <view class="titleRow">
            <view class="pill heroType">{{recipe.type === 'staple' ? '🍚 主食' : (recipe.type === 'protein' ? '🥚 蛋白质' : (recipe.type === 'soup' ? '🍲 汤羹' : '🥬 蔬菜'))}}</view>
            <view class="detailTitleInline">{{recipe.name}}</view>
          </view>
          <view class="muted">预计用时：{{recipe.timeMinutes}} 分钟</view>
          <view wx:if="{{recipe.isSnapshotFallback}}" class="snapshotNotice">这是收藏快照，原食谱更新后依然帮你保留下来啦。</view>
        </view>
        <view class="iconFavoriteBtn {{isFavorite ? 'iconFavoriteBtnActive' : ''}}" bindtap="toggleFavorite">
          <view class="favoriteHeart {{isFavorite ? 'favoriteHeartActive' : ''}}">
            <view class="favoriteHeartInner {{isFavorite ? 'favoriteHeartInnerActive' : ''}}"></view>
          </view>
        </view>
      </view>
    </view>

    <view class="card section softCard">
      <view class="sectionTitle">🧺 食材清单</view>
      <view class="list">
        <view wx:for="{{recipe.ingredients}}" wx:key="name" class="line ingredientLine">
          <view class="name">{{item.name}}</view>
          <view class="ingredientAmount">{{item.amount}}</view>
        </view>
      </view>
    </view>

    <view class="card section softCard">
      <view class="sectionTitle">🍳 做法步骤</view>
      <view class="list">
        <view wx:for="{{recipe.steps}}" wx:key="*this" class="step">
          <view class="num">{{index + 1}}</view>
          <view class="txt">{{item}}</view>
        </view>
      </view>
    </view>
  </view>
</view>
